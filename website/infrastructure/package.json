{
  "name": "migralog-infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for MigraLog website",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "synth:staging": "cdk synth MigraLogWebsiteStack-staging",
    "synth:production": "cdk synth MigraLogWebsiteStack-production",
    "diff:staging": "cdk diff MigraLogWebsiteStack-staging",
    "diff:production": "cdk diff MigraLogWebsiteStack-production",
    "synth:oidc": "cdk synth MigraLogWebsiteOidc",
    "diff:oidc": "cdk diff MigraLogWebsiteOidc",
    "deploy:staging": "cdk deploy MigraLogWebsiteStack-staging --require-approval never",
    "deploy:production": "cdk deploy MigraLogWebsiteStack-production",
    "deploy:oidc": "cdk deploy MigraLogWebsiteOidc --require-approval never",
    "deploy:all": "cdk deploy --all",
    "destroy:staging": "cdk destroy MigraLogWebsiteStack-staging",
    "destroy:production": "cdk destroy MigraLogWebsiteStack-production",
    "bootstrap": "cdk bootstrap"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.150.0",
    "source-map-support": "^0.5.21",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.150.0",
    "constructs": "^10.3.0"
  }
}
